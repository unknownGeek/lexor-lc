{
    "manifest_version": 3,
    "name": "Problem Description Extractor",
    "description": "Extracts and saves sanitized problem descriptions from LeetCode pages to Downloads/lexor-lc/.",
    "version": "1.0",
    "icons": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    },
    "permissions": [
      "activeTab",
      "scripting",
      "storage",
      "downloads",
      "notifications"
    ],
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["*://leetcode.com/*", "*://*.leetcode.com/*"],
        "js": ["webpage_format/sanitizer_core.js", "webpage_content_extractor.js"],
        "run_at": "document_idle"
      }
    ],
    "action": {
      "default_popup": "popup.html",
      "default_icon": "icons/icon.png"
    }
  }
  